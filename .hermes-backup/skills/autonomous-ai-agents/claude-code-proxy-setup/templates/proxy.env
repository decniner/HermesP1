# claude-code-proxy .env — Paste this into the repo root and fill in your key
# See: https://github.com/fuergaosi233/claude-code-proxy

OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_API_KEY="sk-or-v1-<your-key-here>"
BIG_MODEL="openrouter/free"
MIDDLE_MODEL="openrouter/free"
SMALL_MODEL="openrouter/free"
HOST="127.0.0.1"
PORT=8082
LOG_LEVEL="INFO"
