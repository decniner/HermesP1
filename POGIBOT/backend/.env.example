# ═══════════════════════════════════════════════════════════════
# POGIBOT VR Boxing AI Coach — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real keys.
#   cp .env.example .env
# Then edit .env with your credentials.
#
# WARNING: .env contains secrets — NEVER commit it to git.

# ── Gemini API (Video Analysis — Free Tier) ──────────────────
# Get your API key at: https://aistudio.google.com/apikey
# The free tier uses gemini-2.0-flash or gemini-1.5-flash models.
GEMINI_API_KEY=your-gemini-api-key-here

# ── DeepSeek API (No-BS Coach Brain) ─────────────────────────
# Sign up at: https://platform.deepseek.com/  → API Keys
# Your subscription key goes here.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ── Google Sheets (Session History Database) ─────────────────
# The Sheet ID is the long string in your sheet's URL:
#   https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# ── CORS Origin (GitHub Pages domain) ────────────────────────
# The domain where your frontend is hosted. For local dev, leave
# as localhost:5500 or your GitHub Pages URL.
# Example: https://decniner.github.io
CORS_ORIGIN=*
