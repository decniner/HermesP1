# Ignore Python cache
__pycache__/
*.pyc
*.pyo
.env
venv/
.venv/

# Ignore OS files
Thumbs.db
.DS_Store

# Ignore IDE files
.vscode/
.idea/

# Temp artifacts
.hermes-tmp.*

# Never push .env files even inside backup
.hermes-backup/**/.env
.hermes-backup/profiles/

# But DO track everything else in .hermes-backup
!.hermes-backup/memories/
!.hermes-backup/skills/
