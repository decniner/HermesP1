# BrutalMarketEngine - API Configuration
# Copy this file to .env and fill in your credentials.

# Your DeepSeek API key (or any OpenAI-compatible endpoint)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Base URL for your OpenAI-compatible API endpoint
# DeepSeek: https://api.deepseek.com/v1
# OpenRouter: https://openrouter.ai/api/v1
# Local (Ollama/LM Studio): http://127.0.0.1:1234/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: override the model name (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat
